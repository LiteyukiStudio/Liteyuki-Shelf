{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Liteyuki Shelf",
  "version": "0.1.0",
  "identifier": "com.liteyuki.shelf",
  "build": {
    "frontendDist": "../../web/dist",
    "beforeDevCommand": "pnpm --dir ../web dev",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Liteyuki Shelf",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 26
    }
  }
}
